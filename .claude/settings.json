{
    "apiKeyHelper": "echo $ANTHROPIC_API_KEY",
    "model": "claude-sonnet-4-6",
    "statusLine": {
        "type": "command",
        "command": "$CLAUDE_PROJECT_DIR/.claude/statusline.sh"
    },
    "attribution": {
        "commit": "",
        "pr": ""
    },
    "hooks": {
        "PostToolUse": [
            {
                "matcher": "Write|Edit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/format-java.sh",
                        "timeout": 120,
                        "statusMessage": "Formatiere Java (Spotless)…"
                    }
                ]
            }
        ]
    },
    "enableAllProjectMcpServers": true,
    "enabledMcpjsonServers": [
        "context7",
        "playwright"
    ]
}